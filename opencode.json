{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen-32k": {
          "name": "Qwen 2.5 Coder 32B"
        }
      }
    }
  },
  "model": "ollama/qwen-32k",
  "agent": {
    "options": {
      "ignore": [
        "**/target/**",
        "**/*.class",
        "**/*.jar",
        "**/build/**",
        "**/.idea/**",
        "**/.DS_Store"
      ]
    }
  }
}